<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Where Should We Go for Drinks Tonight?</title>
    <style>
        * { margin: 0; padding: 0; box-sizing: border-box; }

        body {
            font-family: 'Georgia', serif;
            background: #0a1628;
            color: #eee;
            min-height: 100vh;
            display: flex;
            flex-direction: column;
            align-items: center;
            padding: 40px 20px;
        }

        h1 {
            font-size: 2.4rem;
            text-align: center;
            margin-bottom: 10px;
            background: linear-gradient(135deg, #87ceeb, #4ab3e2, #b0e0f6);
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
        }

        .subtitle {
            font-size: 1.1rem;
            color: #7eb8d8;
            margin-bottom: 50px;
            font-style: italic;
        }

        .cards {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
            gap: 30px;
            max-width: 1000px;
            width: 100%;
        }

        .card {
            background: #0f2038;
            border-radius: 16px;
            padding: 40px 30px;
            text-align: center;
            cursor: pointer;
            transition: transform 0.3s, box-shadow 0.3s;
            border: 2px solid rgba(135, 206, 235, 0.2);
            position: relative;
            overflow: hidden;
        }

        .card:hover {
            transform: translateY(-8px);
            box-shadow: 0 12px 40px rgba(135, 206, 235, 0.25);
            border-color: rgba(135, 206, 235, 0.5);
        }

        .card .icon {
            font-size: 4rem;
            margin-bottom: 20px;
        }

        .card h2 {
            font-size: 1.6rem;
            margin-bottom: 4px;
            color: #87ceeb;
        }

        .card .location {
            font-size: 0.85rem;
            color: #5a9fbf;
            margin-bottom: 14px;
        }

        .card p {
            color: #9ac0d8;
            line-height: 1.6;
            font-size: 0.95rem;
        }

        .card .vibe {
            margin-top: 18px;
            display: inline-block;
            padding: 6px 16px;
            border-radius: 20px;
            font-size: 0.85rem;
            font-weight: bold;
            letter-spacing: 0.5px;
            background: rgba(135, 206, 235, 0.15);
            color: #87ceeb;
        }

        .card.selected {
            transform: translateY(-8px) scale(1.03);
            border-color: #87ceeb;
        }

        .card.selected::after {
            content: "LET'S GO HERE";
            position: absolute;
            bottom: 0;
            left: 0;
            right: 0;
            padding: 12px;
            font-size: 0.9rem;
            font-weight: bold;
            letter-spacing: 2px;
            color: #fff;
            background: linear-gradient(135deg, #2980b9, #3daee0);
        }

        .result {
            margin-top: 50px;
            font-size: 1.4rem;
            text-align: center;
            opacity: 0;
            transition: opacity 0.5s;
            line-height: 1.8;
            color: #b0e0f6;
        }

        .result.visible {
            opacity: 1;
        }

        .result a {
            color: #87ceeb;
            text-decoration: underline;
            font-weight: bold;
        }

        canvas#fireworks {
            position: fixed;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            pointer-events: none;
            z-index: 999;
        }

        footer {
            margin-top: auto;
            padding-top: 60px;
            color: #3a6a85;
            font-size: 0.85rem;
        }
    </style>
</head>
<body>
    <h1>Where Should We Go for Drinks Tonight?</h1>
    <p class="subtitle">Pick one, and let's make it happen</p>

    <div class="cards">
        <div class="card" onclick="pick(this, 'wine')">
            <div class="icon">🍷</div>
            <h2>Compagnie des Vins Surnaturels</h2>
            <div class="location">249 Centre St, SoHo</div>
            <p>A Parisian-style wine bar with an incredible by-the-glass list. Dim candle-lit room, exposed brick, and sommeliers who actually make wine fun. Perfect date night energy.</p>
            <span class="vibe">Wine Bar</span>
        </div>

        <div class="card" onclick="pick(this, 'dive')">
            <div class="icon">🍺</div>
            <h2>Lucy's</h2>
            <div class="location">135 Ave A, East Village</div>
            <p>A no-frills East Village classic with cheap drinks, a killer jukebox, and zero pretension. The kind of place where you lose track of time and leave best friends with a stranger.</p>
            <span class="vibe">Dive Bar</span>
        </div>

        <div class="card" onclick="pick(this, 'cocktail')">
            <div class="icon">🍸</div>
            <h2>Attaboy</h2>
            <div class="location">134 Eldridge St, Lower East Side</div>
            <p>No menu — just tell the bartender what you're in the mood for and they'll craft something incredible. Intimate speakeasy vibes from the team behind Milk & Honey. World-class cocktails.</p>
            <span class="vibe">Cocktail Lounge</span>
        </div>
    </div>

    <canvas id="fireworks"></canvas>
    <div class="result" id="result"></div>

    <footer>Tonight's going to be good either way.</footer>

    <script>
        const places = {
            wine: {
                message: "Compagnie des Vins Surnaturels it is! Grab a table in the back, order a bottle of natural wine, and enjoy the SoHo vibes.",
                maps: "https://maps.apple.com/?address=249+Centre+St,+New+York,+NY+10013&q=Compagnie+des+Vins+Surnaturels"
            },
            dive: {
                message: "Lucy's! Cheap drinks, good music, and the best kind of unpredictable night. East Village is calling!",
                maps: "https://maps.apple.com/?address=135+Ave+A,+New+York,+NY+10009&q=Lucy's"
            },
            cocktail: {
                message: "Attaboy — excellent choice. Tell the bartender your vibe and let the magic happen. This is going to be a good one.",
                maps: "https://maps.apple.com/?address=134+Eldridge+St,+New+York,+NY+10002&q=Attaboy"
            }
        };

        function pick(card, type) {
            document.querySelectorAll('.card').forEach(c => c.classList.remove('selected'));
            card.classList.add('selected');
            const result = document.getElementById('result');
            const place = places[type];
            result.innerHTML = place.message + '<br><a href="' + place.maps + '" target="_blank">Open in Apple Maps</a>';
            result.classList.add('visible');
            launchFireworks();
        }

        // Fireworks
        const canvas = document.getElementById('fireworks');
        const ctx = canvas.getContext('2d');
        let particles = [];
        let animating = false;
        let animFrame;

        function resize() {
            canvas.width = window.innerWidth;
            canvas.height = window.innerHeight;
        }
        window.addEventListener('resize', resize);
        resize();

        class Particle {
            constructor(x, y, color) {
                this.x = x;
                this.y = y;
                this.color = color;
                const angle = Math.random() * Math.PI * 2;
                const speed = Math.random() * 6 + 2;
                this.vx = Math.cos(angle) * speed;
                this.vy = Math.sin(angle) * speed;
                this.alpha = 1;
                this.decay = Math.random() * 0.015 + 0.008;
                this.size = Math.random() * 3 + 1;
            }
            update() {
                this.x += this.vx;
                this.y += this.vy;
                this.vy += 0.05;
                this.alpha -= this.decay;
            }
            draw() {
                ctx.save();
                ctx.globalAlpha = this.alpha;
                ctx.fillStyle = this.color;
                ctx.beginPath();
                ctx.arc(this.x, this.y, this.size, 0, Math.PI * 2);
                ctx.fill();
                ctx.restore();
            }
        }

        function explode(x, y) {
            const colors = ['#87ceeb', '#b0e0f6', '#4ab3e2', '#ffffff', '#a0d8ef', '#5bc0de', '#e0f4ff'];
            for (let i = 0; i < 80; i++) {
                particles.push(new Particle(x, y, colors[Math.floor(Math.random() * colors.length)]));
            }
        }

        function animate() {
            ctx.clearRect(0, 0, canvas.width, canvas.height);
            particles = particles.filter(p => p.alpha > 0);
            particles.forEach(p => { p.update(); p.draw(); });
            if (particles.length > 0) {
                animFrame = requestAnimationFrame(animate);
            } else {
                animating = false;
                ctx.clearRect(0, 0, canvas.width, canvas.height);
            }
        }

        function launchFireworks() {
            if (animating) {
                cancelAnimationFrame(animFrame);
                particles = [];
            }
            animating = true;
            const bursts = 5;
            for (let i = 0; i < bursts; i++) {
                setTimeout(() => {
                    const x = Math.random() * canvas.width * 0.6 + canvas.width * 0.2;
                    const y = Math.random() * canvas.height * 0.4 + canvas.height * 0.1;
                    explode(x, y);
                }, i * 400);
            }
            animate();
        }
    </script>
</body>
</html>
